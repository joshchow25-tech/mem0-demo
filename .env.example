# 通义千问 API Key（阿里云 DashScope）
# 格式示例: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 请到 https://dashscope.aliyuncs.com 控制台创建 API-KEY
DASHSCOPE_API_KEY=sk-your-real-dashscope-key-here

# Qwen 模型配置
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3

# ChromaDB 配置（本地持久化路径）
CHROMA_PERSIST_PATH=./data/chroma_db

# mem0 配置
# 使用本地 ChromaDB 作为 mem0 向量存储

# 应用配置
APP_PORT=8000
APP_HOST=0.0.0.0
DEBUG=true
